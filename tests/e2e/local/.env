# PostgreSQL Database (public registry)
POSTGRES_IMAGE=postgres:17.4

# JFrog Platform Services
# Update <YOUR_REGISTRY> with your JFrog registry URL (e.g., docker.jfrog.io or your custom registry)
ARTIFACTORY_IMAGE=<YOUR_REGISTRY>/jfrog/artifactory-pro:7.125.0
EVIDENCE_IMAGE=<YOUR_REGISTRY>/jfrog/evidence:7.193.0

# OneModel Services
ONEMODEL_VERSION=1.55.0
ROUTER_IMAGE=<YOUR_REGISTRY>/jfrog/router:7.165.3
ONEMODEL_APOLLO_IMAGE=<YOUR_REGISTRY>/jfrog/onemodelapollo:1.55.0
ONEMODEL_REGISTRY_IMAGE=<YOUR_REGISTRY>/jfrog/onemodelregistry:1.55.0

# Logging Levels
EVIDENCE_LOG_LEVEL=info
APOLLO_LOG_LEVEL=info
